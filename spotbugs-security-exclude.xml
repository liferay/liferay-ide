<FindBugsFilter>

	<!-- False positive: executed without a shell, so command arguments containing metacharacters cannot inject or chain additional commands -->

	<Match>
		<Bug pattern="COMMAND_INJECTION" />
		<Class name="com.liferay.ide.server.ui.util.ServerUIUtil" />
		<Method name="openInSystemExplorer" />
	</Match>

	<!-- False positive: executed without a shell, so the workspace path cannot be exploited to inject or chain additional commands -->

	<Match>
		<Bug pattern="COMMAND_INJECTION" />
		<Class name="com.liferay.ide.ui.workspace.LaunchWorkspaceHandler" />
		<Method name="execute" />
	</Match>

	<!-- Only loads .groovy scripts bundled in the plugin, not user input -->

	<Match>
		<Bug pattern="GROOVY_SHELL" />
		<Class name="com.liferay.ide.scripting.core.GroovyScriptingSupport" />
		<Method name="newInstanceFromFile" />
	</Match>

	<!-- False positive: hard coded password is the default for a testcase only -->

	<Match>
		<Bug pattern="HARD_CODE_PASSWORD" />
		<Class name="com.liferay.ide.server.core.tests.ServerManagerTests" />
		<Method name="startServer" />
	</Match>

	<!--
	StringUtil.equalsIgnoreCase(String, Object) already uses
	toLowerCase(Locale.ROOT) internally. SpotBugs flags the call
	because it cannot verify the Locale parameter through static analysis.
	-->
	<Match>
		<Class name="com.liferay.ide.core.util.StringUtil" />
		<Method name="equalsIgnoreCase" />
		<Bug pattern="IMPROPER_UNICODE" />
	</Match>

	<!--
	StringUtil.toLowerCase(String) already passes Locale.ROOT to
	String.toLowerCase(). SpotBugs flags it because it treats any
	toLowerCase call as suspect regardless of the Locale argument.
	-->
	<Match>
		<Class name="com.liferay.ide.core.util.StringUtil" />
		<Method name="toLowerCase" />
		<Bug pattern="IMPROPER_UNICODE" />
	</Match>

	<!-- Test failure messages intentionally include stack traces for developer diagnostics -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.core.tests.BaseTests" />
		<Method name="failTest" />
	</Match>

	<!-- Test failure messages intentionally include stack traces for developer diagnostics -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.core.tests.TestUtil" />
		<Method name="failTest" />
	</Match>

	<!-- Utility converts a Throwable to a stack trace string; callers control how the result is used -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.core.util.CoreUtil" />
		<Method name="getStackTrace" />
	</Match>

	<!-- Console transfer listener; printing transfer error details to output is expected behavior -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.maven.core.aether.ConsoleTransferListener" />
		<Method name="transferCorrupted" />
	</Match>

	<!-- Console transfer listener; printing transfer error details to output is expected behavior -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.maven.core.aether.ConsoleTransferListener" />
		<Method name="transferFailed" />
	</Match>

	<!-- Eclipse form's error-details panel intentionally displays the stack trace to the developer -->

	<Match>
		<Bug pattern="INFORMATION_EXPOSURE_THROUGH_AN_ERROR_MESSAGE" />
		<Class name="com.liferay.ide.ui.form.IDEFormPage" />
		<Method name="_getStackTrace" />
	</Match>

	<!-- False positive: regex matches an internal DOCTYPE string, not untrusted input -->

	<Match>
		<Bug pattern="MODIFICATION_AFTER_VALIDATION" />
		<Class name="com.liferay.ide.maven.core.LiferayMavenProjectProvider" />
		<Method name="_getNewDoctTypeSetting" />
	</Match>

	<!-- False positive: internal version string formatting (dots to underscores), not untrusted input -->

	<Match>
		<Bug pattern="MODIFICATION_AFTER_VALIDATION" />
		<Class name="com.liferay.ide.maven.core.util.DefaultMaven2OsgiConverter" />
		<Method name="getVersion" />
	</Match>

	<!-- Local bind()-then-close to test port availability; no client connects and no data is transmitted -->

	<Match>
		<Bug pattern="UNENCRYPTED_SERVER_SOCKET" />
		<Class name="com.liferay.ide.server.util.SocketUtil" />
		<Method name="isPortAvailable" />
	</Match>

	<!-- Gogo OSGi console uses the telnet protocol (per class Javadoc); endpoint is not SSL -->

	<Match>
		<Bug pattern="UNENCRYPTED_SOCKET" />
		<Class name="com.liferay.ide.server.core.gogo.GogoShellClient" />
		<Method name="&lt;init&gt;" />
	</Match>

	<!-- TCP reachability probe to a user-configured remote port; the remote server dictates the wire protocol -->

	<Match>
		<Bug pattern="UNENCRYPTED_SOCKET" />
		<Class name="com.liferay.ide.server.remote.RemoteServer" />
		<Method name="canMakeHttpConnection" />
	</Match>

	<!-- Reachability probe: socket is bound, connected, and immediately closed without sending data -->

	<Match>
		<Bug pattern="UNENCRYPTED_SOCKET" />
		<Class name="com.liferay.ide.server.util.SocketUtil" />
		<Method name="canConnect" />
	</Match>

	<!-- Reachability probe (proxy variant): bound, connected, and immediately closed without sending data -->

	<Match>
		<Bug pattern="UNENCRYPTED_SOCKET" />
		<Class name="com.liferay.ide.server.util.SocketUtil" />
		<Method name="canConnectProxy" />
	</Match>

